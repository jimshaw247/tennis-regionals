# Client-visible (bundled into the JS). Public.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...
VITE_ADMIN_USER=admin
VITE_ADMIN_PASS=changeme

# Server-only. Vercel env vars (no VITE_ prefix). Keep secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...    # the service_role key, NOT anon
ADMIN_PASS=changeme                    # must match VITE_ADMIN_PASS
